# ============================================================
# BotKeuangan — Environment Variables
# Salin file ini menjadi .env dan isi sesuai konfigurasi kamu
#   cp .env.example .env
#   nano .env
# ============================================================

# ── PostgreSQL ────────────────────────────────────────
POSTGRES_USER=finance_user
POSTGRES_PASSWORD=ganti_password_ini_yang_kuat
POSTGRES_DB=finance_db

# ── Google Gemini API ─────────────────────────────────
# Dapatkan di https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ── WhatsApp ──────────────────────────────────────────
# Nomor WA pemilik (format: 628xxxxxxxxxx, tanpa + atau -)
OWNER_WA_NUMBER=628123456789

# ── Domain & URL ──────────────────────────────────────
# Domain untuk dashboard (tanpa https://)
DOMAIN=localhost
# Domain untuk API (tanpa https://)
API_DOMAIN=api.localhost

# URL backend yang bisa diakses browser
# Lokal      : http://localhost/api   (via Nginx proxy)
# Production : https://api.domain-kamu.com
NEXT_PUBLIC_BACKEND_URL=http://localhost:3002

# ── Ports ─────────────────────────────────────────────
# Port yang di-expose ke host (via Nginx)
HTTP_PORT=80
HTTPS_PORT=443
